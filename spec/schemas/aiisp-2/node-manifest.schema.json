{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://97115104.github.io/aiisp-spec/schemas/aiisp-2/node-manifest.schema.json",
  "title": "AIISP-2 Node Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "node_id",
    "operator",
    "endpoint",
    "supported_categories",
    "supported_models",
    "settlement_wallet",
    "energy_region",
    "measurement_method",
    "software_version"
  ],
  "properties": {
    "version": {
      "const": "aiisp-2"
    },
    "node_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    },
    "operator": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    },
    "endpoint": {
      "type": "string",
      "format": "uri"
    },
    "public_key": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "did_document": {
      "type": "string",
      "format": "uri"
    },
    "supported_categories": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/category"
      }
    },
    "supported_models": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["model", "category"],
        "properties": {
          "model": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256
          },
          "category": {
            "$ref": "#/$defs/category"
          },
          "max_context_tokens": {
            "type": "integer",
            "minimum": 1
          }
        }
      }
    },
    "settlement_wallet": {
      "type": "string",
      "pattern": "^0x[a-fA-F0-9]{40}$"
    },
    "energy_region": {
      "type": "string",
      "minLength": 2,
      "maxLength": 64
    },
    "measurement_method": {
      "type": "string",
      "enum": ["measured", "model_benchmark", "node_estimate", "registry_default"]
    },
    "software_version": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "terms_url": {
      "type": "string",
      "format": "uri"
    },
    "health_url": {
      "type": "string",
      "format": "uri"
    }
  },
  "$defs": {
    "category": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{1,63}$"
    }
  }
}
