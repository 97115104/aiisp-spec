{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://97115104.github.io/aiisp-spec/schemas/aiisp-2/inference-request.schema.json",
  "title": "AIISP-2 Inference Request Body",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "model": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    },
    "messages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["role", "content"],
        "properties": {
          "role": {
            "type": "string",
            "enum": ["system", "user", "assistant", "tool", "developer"]
          },
          "content": {
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "array"
              },
              {
                "type": "object"
              }
            ]
          },
          "name": {
            "type": "string"
          },
          "tool_call_id": {
            "type": "string"
          }
        }
      }
    },
    "input": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "array"
        },
        {
          "type": "object"
        }
      ]
    },
    "temperature": {
      "type": "number",
      "minimum": 0
    },
    "max_tokens": {
      "type": "integer",
      "minimum": 1
    },
    "stream": {
      "type": "boolean"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "anyOf": [
    {
      "required": ["messages"]
    },
    {
      "required": ["input"]
    }
  ]
}
