{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://97115104.github.io/aiisp-spec/schemas/aiisp-2/inference-response.schema.json",
  "title": "AIISP-2 Inference Response Body",
  "type": "object",
  "additionalProperties": true,
  "required": ["id", "model", "aiisp"],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "object": {
      "type": "string"
    },
    "created": {
      "type": "integer",
      "minimum": 0
    },
    "model": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    },
    "choices": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "usage": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "prompt_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "completion_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "total_tokens": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "aiisp": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "version",
        "category",
        "model",
        "node",
        "settlement_event",
        "settlement_batch"
      ],
      "properties": {
        "version": {
          "const": "aiisp-2"
        },
        "category": {
          "$ref": "#/$defs/category"
        },
        "model": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "node": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "settlement_event": {
          "type": "string",
          "minLength": 8,
          "maxLength": 128
        },
        "settlement_batch": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "settlement_tx": {
          "type": "string",
          "pattern": "^0x[a-fA-F0-9]{64}$"
        },
        "environmental_line": {
          "$ref": "./environmental-line.schema.json"
        }
      }
    }
  },
  "$defs": {
    "category": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{1,63}$"
    }
  }
}
