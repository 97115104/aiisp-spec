{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://97115104.github.io/aiisp-spec/schemas/aiisp-2/environmental-line.schema.json",
  "title": "AIISP-2 Environmental Line",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "energy_kwh",
    "carbon_kg_co2e",
    "water_liters",
    "region",
    "measurement_method",
    "remediation_usd",
    "remediation_targets"
  ],
  "properties": {
    "energy_kwh": {
      "$ref": "#/$defs/decimalString"
    },
    "carbon_kg_co2e": {
      "$ref": "#/$defs/decimalString"
    },
    "water_liters": {
      "$ref": "#/$defs/decimalString"
    },
    "region": {
      "type": "string",
      "minLength": 2,
      "maxLength": 64,
      "examples": ["us-west-2", "CA-LAX", "EU-DE"]
    },
    "measurement_method": {
      "type": "string",
      "enum": ["measured", "model_benchmark", "node_estimate", "registry_default"]
    },
    "methodology_version": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "rate_source": {
      "type": "string",
      "format": "uri"
    },
    "remediation_usd": {
      "$ref": "#/$defs/decimalString"
    },
    "remediation_targets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "amount_usd"],
        "properties": {
          "kind": {
            "type": "string",
            "enum": ["carbon", "water", "energy", "community"]
          },
          "amount_usd": {
            "$ref": "#/$defs/decimalString"
          },
          "recipient": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256
          }
        }
      }
    },
    "notes": {
      "type": "string",
      "maxLength": 512
    }
  },
  "$defs": {
    "decimalString": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)(\\.[0-9]+)?$"
    }
  }
}
